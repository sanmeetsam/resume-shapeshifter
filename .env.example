# Groq (required from Phase 2 onward) — https://console.groq.com
GROQ_API_KEY=

# OpenAI-compatible base URL (default shown; override only if needed)
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Model for JD extraction, scoring, tailoring, and gap analysis
# See https://console.groq.com/docs/models
LLM_MODEL=llama-3.3-70b-versatile

# Maximum resume upload size in megabytes (Phase 5 file upload)
MAX_UPLOAD_MB=5

# Per-IP requests per minute for /api/tailor and /api/export/pdf (Phase 5)
API_RATE_LIMIT_PER_MIN=10

# PDF renderer: playwright | react-pdf (Phase 3)
PDF_RENDERER=playwright

# Vercel (optional — set in Vercel dashboard for serverless Chromium)
# AWS_LAMBDA_JS_RUNTIME=nodejs22.x

# Optional persistent storage (future)
# DATABASE_URL=
